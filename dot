#!/bin/sh
# =============================================================================
# dot — install, verify, and healthcheck these dot files
# =============================================================================
#
# Usage:
#   ./dot install [-p PROFILE] [-m symlink|copy] [-n] [-f]
#   ./dot check   [-p PROFILE]
#   ./dot doctor  [-p PROFILE]
#   ./dot help
#
# Profiles:
#   full     everything for a dev machine (default)
#   server   quick-poke kit: bashrc, vimrc, tmux.conf
#
# Options (install):
#   -m METHOD   "symlink" (default) or "copy"
#   -n          dry run — show what would happen without doing it
#   -f          force — replace existing files without backup
#
# New machine:
#   git clone https://github.com/mjhika/dot-files && cd dot-files && ./dot install
#   ./dot doctor
#
# Server:
#   git clone --depth 1 https://github.com/mjhika/dot-files && cd dot-files
#   ./dot install -p server
#
# =============================================================================

set -eu

REPO_ROOT=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd -P)
MANIFEST="$REPO_ROOT/manifest"

case "$(uname -s)" in
    Darwin)  OS=darwin ;;
    Linux)   OS=linux ;;
    FreeBSD) OS=freebsd ;;
    *)       OS=other ;;
esac

# -- ( OUTPUT HELPERS ) -------------------------------------------------------

if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    C_BLU='\033[1;34m'; C_YEL='\033[1;33m'; C_RED='\033[1;31m'; C_GRN='\033[1;32m'; C_OFF='\033[0m'
else
    C_BLU=''; C_YEL=''; C_RED=''; C_GRN=''; C_OFF=''
fi

info() { printf "  ${C_BLU}::${C_OFF} %s\n" "$1"; }
warn() { printf "  ${C_YEL}::${C_OFF} %s\n" "$1"; }
err()  { printf "  ${C_RED}::${C_OFF} %s\n" "$1"; }
ok()   { printf "  ${C_GRN}::${C_OFF} %s\n" "$1"; }
head_() { printf "\n%s\n" "$1"; }

usage() {
    sed -n '/^# Usage:/,/^# ====/{/^# ====/d;s/^# \{0,1\}//;p;}' "$0"
}

timestamp() { date +%Y%m%d_%H%M%S; }

# -- ( MANIFEST ITERATION ) ---------------------------------------------------
# Calls "$1 <repo-path> <target>" for every manifest entry matching this OS
# and the active profile. Columns: <src> <dst> [os] [profiles]
#   os:       "any" (or omitted) matches everywhere, else comma list
#   profiles: comma list, omitted means "full"

PROFILE=full

set_profile() {
    case "$1" in
        full|server) PROFILE="$1" ;;
        *) err "invalid profile: $1 (use 'full' or 'server')"; exit 1 ;;
    esac
}

each_entry() {
    while read -r _src _dst _osf _prof _junk || [ -n "${_src:-}" ]; do
        case "${_src:-}" in ''|'#'*) continue ;; esac
        if [ -z "${_dst:-}" ]; then
            err "malformed manifest line: $_src"
            continue
        fi
        case "${_osf:-any}" in
            any) ;;
            *)
                case ",$_osf," in
                    *",$OS,"*) ;;
                    *) continue ;;
                esac
                ;;
        esac
        case ",${_prof:-full}," in
            *",$PROFILE,"*) ;;
            *) continue ;;
        esac
        "$1" "$_src" "$_dst"
    done < "$MANIFEST"
}

# -- ( INSTALL ) --------------------------------------------------------------

METHOD=symlink
DRY=0
FORCE=0
STAMP=$(timestamp)
INSTALL_FAIL=0

install_entry() {
    _s="$REPO_ROOT/$1"
    _d="$HOME/$2"

    if [ ! -e "$_s" ]; then
        err "missing in repo: $1"
        INSTALL_FAIL=1
        return 0
    fi

    # already correct?
    if [ "$METHOD" = symlink ] && [ -L "$_d" ] && [ "$(readlink "$_d")" = "$_s" ]; then
        ok "linked      ~/$2"
        return 0
    fi
    if [ "$METHOD" = copy ] && [ ! -L "$_d" ] && [ -e "$_d" ] \
        && diff -rq "$_s" "$_d" >/dev/null 2>&1; then
        ok "current     ~/$2"
        return 0
    fi

    # deal with whatever is in the way
    if [ -e "$_d" ] || [ -L "$_d" ]; then
        if [ "$FORCE" -eq 1 ] || [ -L "$_d" ]; then
            # stale symlinks are safe to drop; real files only with -f
            if [ "$DRY" -eq 1 ]; then
                info "[dry-run] rm ~/$2"
            else
                rm -rf "$_d"
            fi
        else
            if [ "$DRY" -eq 1 ]; then
                info "[dry-run] backup ~/$2 -> ~/$2.bak.$STAMP"
            else
                mv "$_d" "$_d.bak.$STAMP"
                info "backed up   ~/$2 -> ~/$2.bak.$STAMP"
            fi
        fi
    fi

    if [ "$DRY" -eq 1 ]; then
        info "[dry-run] $METHOD $1 -> ~/$2"
        return 0
    fi

    mkdir -p "$(dirname "$_d")"
    case "$METHOD" in
        symlink) ln -s "$_s" "$_d" && ok "linked      ~/$2" ;;
        copy)    cp -R "$_s" "$_d" && ok "copied      ~/$2" ;;
    esac
}

do_install() {
    while getopts "m:nfp:" _opt; do
        case "$_opt" in
            p) set_profile "$OPTARG" ;;
            m)
                case "$OPTARG" in
                    symlink|copy) METHOD="$OPTARG" ;;
                    *) err "invalid method: $OPTARG (use 'symlink' or 'copy')"; exit 1 ;;
                esac
                ;;
            n) DRY=1 ;;
            f) FORCE=1 ;;
            ?) usage; exit 1 ;;
        esac
    done

    info "os: $OS  profile: $PROFILE  method: $METHOD$( [ "$DRY" -eq 1 ] && printf ' (dry run)' )"
    echo ""
    each_entry install_entry

    # support dirs the configs expect but can't create themselves
    for _dir in "$HOME/.vim/undodir" "$HOME/.local/share" "$HOME/.cache"; do
        if [ ! -d "$_dir" ]; then
            if [ "$DRY" -eq 1 ]; then
                info "[dry-run] mkdir -p $_dir"
            else
                mkdir -p "$_dir"
                info "created     $_dir"
            fi
        fi
    done

    echo ""
    if [ "$INSTALL_FAIL" -eq 1 ]; then
        err "finished with errors"
        exit 1
    fi
    ok "done"
}

# -- ( CHECK ) ----------------------------------------------------------------

CHECK_FAIL=0

check_entry() {
    _s="$REPO_ROOT/$1"
    _d="$HOME/$2"

    if [ ! -e "$_d" ] && [ ! -L "$_d" ]; then
        err "missing     ~/$2"
        CHECK_FAIL=1
    elif [ -L "$_d" ]; then
        _t=$(readlink "$_d")
        if [ "$_t" = "$_s" ]; then
            ok "linked      ~/$2"
        elif [ ! -e "$_d" ]; then
            err "broken link ~/$2 -> $_t"
            CHECK_FAIL=1
        else
            warn "other link  ~/$2 -> $_t"
            CHECK_FAIL=1
        fi
    else
        if diff -rq "$_s" "$_d" >/dev/null 2>&1; then
            ok "copy, same  ~/$2"
        else
            warn "drifted     ~/$2 (differs from repo)"
            CHECK_FAIL=1
        fi
    fi
}

do_check() {
    while getopts "p:" _opt; do
        case "$_opt" in
            p) set_profile "$OPTARG" ;;
            ?) usage; exit 1 ;;
        esac
    done

    info "checking deployment against manifest (os: $OS, profile: $PROFILE)"
    echo ""
    each_entry check_entry
    echo ""
    if [ "$CHECK_FAIL" -eq 1 ]; then
        err "some entries need attention — run ./dot install"
        exit 1
    fi
    ok "everything deployed"
}

# -- ( DOCTOR ) ---------------------------------------------------------------

DOC_REQ=0
DOC_OPT=0

have() { command -v "$1" >/dev/null 2>&1; }

req() {
    if have "$1"; then
        ok "$(printf '%-11s' "$1") $(command -v "$1")"
    else
        err "$(printf '%-11s' "$1") MISSING (required)"
        DOC_REQ=1
    fi
}

opt() {
    if have "$1"; then
        ok "$(printf '%-11s' "$1") $(command -v "$1")"
    else
        warn "$(printf '%-11s' "$1") missing${2:+ — $2}"
        DOC_OPT=1
    fi
}

req_any() { # space-separated alternates, first found wins
    for _c in $1; do
        if have "$_c"; then
            ok "$(printf '%-11s' "$_c") $(command -v "$_c")"
            return 0
        fi
    done
    err "$(printf '%-11s' "${1%% *}") none of '$1' found (required)"
    DOC_REQ=1
}

# prints the 1-based position of $1 in PATH, or returns 1
path_index() {
    _i=0
    _oifs=$IFS
    IFS=:
    for _p in $PATH; do
        _i=$((_i + 1))
        if [ "$_p" = "$1" ]; then
            IFS=$_oifs
            printf '%s' "$_i"
            return 0
        fi
    done
    IFS=$_oifs
    return 1
}

doctor_summary() {
    echo ""
    if [ "$DOC_REQ" -eq 1 ]; then
        err "required pieces missing"
        info "deployment state: ./dot check${PROFILE:+ -p $PROFILE}"
        exit 1
    elif [ "$DOC_OPT" -eq 1 ]; then
        warn "healthy, with optional pieces missing"
    else
        ok "all healthy"
    fi
    info "deployment state: ./dot check${PROFILE:+ -p $PROFILE}"
}

do_doctor() {
    while getopts "p:" _opt; do
        case "$_opt" in
            p) set_profile "$OPTARG" ;;
            ?) usage; exit 1 ;;
        esac
    done

    # server baseline: just what the server profile's configs need
    if [ "$PROFILE" = server ]; then
        head_ "== server baseline =="
        req bash
        req git
        req_any "curl wget fetch"
        req tmux
        req_any "vi vim nvim"
        doctor_summary
        return 0
    fi

    _data="${XDG_DATA_HOME:-$HOME/.local/share}"
    _shims="$_data/mise/shims"

    head_ "== core =="
    req zsh
    req git
    req_any "curl wget fetch"
    req mise
    req tmux
    req_any "nvim vim"

    head_ "== dx tools =="
    opt fzf
    opt direnv
    opt lazygit
    opt tree
    opt bat
    opt jq
    opt rg "ripgrep"

    head_ "== languages =="
    opt go
    opt clojure
    opt java "required by clojure"
    opt elixir
    opt erl "required by elixir"
    opt node
    req_any "cc clang gcc"
    opt make
    opt shellcheck "shell linting"
    opt shfmt "shell formatting"

    # cross-tool consistency
    if have clojure && ! have java; then
        err "clojure is installed but java is not — clojure cannot run"
        DOC_REQ=1
    fi
    if have elixir && ! have erl; then
        err "elixir is installed but erlang is not — elixir cannot run"
        DOC_REQ=1
    fi

    head_ "== environment =="
    if [ -d "$_shims" ]; then
        _si=$(path_index "$_shims") || _si=""
        _ui=$(path_index /usr/bin) || _ui=""
        if [ -z "$_si" ]; then
            err "mise shims exist but are NOT on PATH ($_shims)"
            DOC_REQ=1
        elif [ -n "$_ui" ] && [ "$_si" -gt "$_ui" ]; then
            warn "mise shims are on PATH but AFTER /usr/bin — system tools shadow mise"
            DOC_OPT=1
        else
            ok "mise shims on PATH ahead of system dirs"
        fi
    else
        warn "mise shims dir not found ($_shims) — run: mise install"
        DOC_OPT=1
    fi

    if have go; then
        case "$(command -v go)" in
            *mise*) ok "go resolves through mise" ;;
            *) warn "go resolves outside mise: $(command -v go)"; DOC_OPT=1 ;;
        esac
    fi

    if [ -n "${XDG_DATA_HOME:-}" ]; then
        ok "XDG_DATA_HOME set ($XDG_DATA_HOME)"
    else
        warn "XDG_DATA_HOME unset — is ~/.zshenv deployed? (using default)"
        DOC_OPT=1
    fi

    if [ -d "$_data" ]; then
        ok "history/data dir exists ($_data)"
    else
        warn "history/data dir missing ($_data) — zsh history won't persist"
        DOC_OPT=1
    fi

    case "${SHELL:-}" in
        */zsh) ok "login shell is zsh" ;;
        *) warn "login shell is '${SHELL:-unset}', not zsh — chsh -s \$(command -v zsh)"; DOC_OPT=1 ;;
    esac

    doctor_summary
}

# -- ( DISPATCH ) -------------------------------------------------------------

[ -f "$MANIFEST" ] || { err "manifest not found: $MANIFEST"; exit 1; }

_cmd="${1:-help}"
[ $# -gt 0 ] && shift

case "$_cmd" in
    install)      do_install "$@" ;;
    check)        do_check "$@" ;;
    doctor)       do_doctor "$@" ;;
    help|-h|--help) usage ;;
    *)            err "unknown command: $_cmd"; usage; exit 1 ;;
esac
